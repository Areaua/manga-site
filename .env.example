# MongoDB connection string (Atlas: mongodb+srv://... или self-hosted: mongodb://user:pass@host:27017/db)
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/dbname

# Название базы данных внутри MongoDB
MONGODB_DB_NAME=manga

# JWT secret key — сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=generate_with_python_-c_import_secrets_print_secrets_token_urlsafe_64

# Алгоритм подписи JWT токенов
JWT_ALGORITHM=HS256

# Время жизни access-токена в минутах
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Путь к папке для хранения аватаров пользователей
AVATARS_DIR=./avatars_storage

# URL фронтенда для CORS (без trailing slash)
FRONTEND_URL=http://localhost:3000

# Frontend env vars (Create React App)
REACT_APP_API_BASE_URL=http://localhost:8000
